<%- include('layout', { title: 'Реєстрація', body: `
  <div class="max-w-md mx-auto bg-zinc-900 p-10 rounded-3xl">
    <h2 class="text-3xl font-bold text-center mb-8">Реєстрація</h2>
    ${error ? `<p class="text-red-400 text-center mb-6">${error}</p>` : ''}
    <form method="POST" action="/register">
      <input name="username" placeholder="Логін" required class="w-full p-5 bg-zinc-800 rounded-2xl mb-4 text-lg">
      <input type="password" name="password" placeholder="Пароль" required class="w-full p-5 bg-zinc-800 rounded-2xl mb-8 text-lg">
      <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 py-5 rounded-2xl text-xl font-medium">Зареєструватись</button>
    </form>
    <p class="text-center mt-8">Вже є акаунт? <a href="/login" class="text-emerald-400">Увійти</a></p>
  </div>
` }) %>